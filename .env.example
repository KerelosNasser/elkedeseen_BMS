# Elkedeseen BMS - Deployment Environment Template
# Copy this to .env.production on the server

# Database connection string (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://user:password@localhost:5432/elkedeseen

# List of admin emails (comma-separated) for notifications
ADMIN_EMAILS=your-admin@example.com

# Secret for the cleanup cron job (e.g. openssl rand -base64 32)
CRON_SECRET=generate-a-strong-random-string

# SMTP Settings for Email Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Elkedeseen BMS" <noreply@example.com>
SMTP_SECURE=false

# Environment settings
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=https://your-domain.com
