# Elkedeseen BMS - Deployment Environment Template
# Copy this to .env.production on the server

# Database connection string (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://user:password@localhost:5432/elkedeseen

# List of admin emails (comma-separated) for notifications
ADMIN_EMAILS=admin@example.com,manager@example.com

# Secret for the cleanup cron job (e.g. openssl rand -base64 32)
CRON_SECRET=generate-a-strong-random-string

# Environment settings
NODE_ENV=production
PORT=3000
